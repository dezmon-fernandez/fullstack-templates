# ===========================================
# Angular + Supabase Template - Environment Variables
# ===========================================
# Angular uses src/environments/environment.ts instead of .env files.
# These values are written to src/environments/environment.development.ts by setup.sh

# -------------------------------------------
# Supabase (Required)
# -------------------------------------------
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key

# -------------------------------------------
# Local Development
# -------------------------------------------
# Start local Supabase: supabase start
# Local Studio URL: http://localhost:54323
# Local API URL: http://localhost:54321
